6%88%91%E7%9A%84%E5%8D%9A%E5%AE%A2/#_2","title":"\u5173\u4e8e\u8fd9\u4e2a\u535a\u5ba2","text":"<p>\u8fd9\u4e2a\u535a\u5ba2\u4f7f\u7528\u6700\u65b0\u7684 Material for MkDocs 9.7.0 \u6784\u5efa\uff0c\u62e5\u6709\uff1a</p> <ul> <li>\ud83c\udf13 \u660e\u4eae/\u6697\u9ed1\u6a21\u5f0f\u5207\u6362</li> <li>\ud83d\udd0d \u5f3a\u5927\u7684\u641c\u7d22\u529f\u80fd</li> <li>\ud83d\udcf1 \u54cd\u5e94\u5f0f\u8bbe\u8ba1</li> <li>\ud83c\udfa8 \u7f8e\u89c2\u7684\u754c\u9762</li> </ul>","tags":["\u5f00\u7bc7","\u4ecb\u7ecd"]},{"location":"blog/2024/03/19/%E6%AC%A2%E8%BF%8E%E6%9D%A5%E5%88%B0%E6%88%91%E7%9A%84%E5%8D%9A%E5%AE%A2/#_3","title":"\u5373\u5c06\u5206\u4eab\u7684\u5185\u5bb9","text":"<ul> <li>\u5de5\u4e1a\u5de5\u7a0b\u5b9e\u6218\u7ecf\u9a8c</li> <li>\u7cfb\u7edf\u67b6\u6784\u8bbe\u8ba1\u601d\u8def</li> <li>\u8fd0\u7b79\u5b66\u5e94\u7528\u6848\u4f8b</li> <li>\u6280\u672f\u5de5\u5177\u548c\u6700\u4f73\u5b9e\u8df5</li> </ul> <p>\u656c\u8bf7\u671f\u5f85\u66f4\u591a\u5185\u5bb9\uff01</p>","tags":["\u5f00\u7bc7","\u4ecb\u7ecd"]},{"location":"config/","title":"\u8fd0\u7ef4\u624b\u518c","text":"<p>\u672c\u9875\u9762\u4ecb\u7ecd\u5982\u4f55\u8fd0\u7ef4\u548c\u7ba1\u7406\u672c\u624b\u518c\uff0c\u5305\u62ec\u672c\u5730\u4f7f\u7528\u3001\u5185\u5bb9\u7ba1\u7406\u3001\u914d\u7f6e\u4fee\u6539\u548c\u90e8\u7f72\u7b49\u64cd\u4f5c\u3002</p>"},{"location":"config/#1","title":"1. \u672c\u5730\u4f7f\u7528","text":""},{"location":"config/#_2","title":"\u5b89\u88c5\u4f9d\u8d56","text":"<p>\u5728\u672c\u5730\u4f7f\u7528\u524d\uff0c\u9700\u8981\u5b89\u88c5\u5fc5\u8981\u7684\u4f9d\u8d56\uff1a</p> <pre><code>pip install mkdocs mkdocs-material mkdocs-minify-plugin\n</code></pre>"},{"location":"config/#_3","title":"\u672c\u5730\u9884\u89c8","text":"<p>\u4fee\u6539\u5185\u5bb9\u540e\uff0c\u53ef\u4ee5\u901a\u8fc7\u4ee5\u4e0b\u547d\u4ee4\u542f\u52a8\u672c\u5730\u670d\u52a1\u5668\u8fdb\u884c\u9884\u89c8\uff1a</p> <pre><code>mkdocs serve\n</code></pre> <p>\u7136\u540e\u5728\u6d4f\u89c8\u5668\u4e2d\u8bbf\u95e