\u680f\u76ee\u9996\u9875: new-section/index.md\n    - \u5b50\u9875\u97621: new-section/page1.md\n    - \u5b50\u9875\u97622: new-section/page2.md\n</code></pre>"},{"location":"config/#4","title":"4. \u65b0\u589e\u56fe\u7247","text":""},{"location":"config/#_9","title":"\u521b\u5efa\u56fe\u7247\u6587\u4ef6\u5939","text":"<p>\u5728 <code>docs</code> \u76ee\u5f55\u4e0b\u521b\u5efa <code>images</code> \u6587\u4ef6\u5939\uff08\u5982\u679c\u4e0d\u5b58\u5728\uff09\uff1a</p> <pre><code>mkdir -p docs/images\n</code></pre>"},{"location":"config/#_10","title":"\u6dfb\u52a0\u56fe\u7247","text":"<ol> <li>\u5c06\u56fe\u7247\u6587\u4ef6\u653e\u5165 <code>docs/images</code> \u6587\u4ef6\u5939\u4e2d</li> <li>\u53ef\u4ee5\u6839\u636e\u680f\u76ee\u6216\u529f\u80fd\u521b\u5efa\u5b50\u6587\u4ef6\u5939\uff0c\u5206\u7c7b\u5b58\u50a8\u56fe\u7247</li> </ol>"},{"location":"config/#_11","title":"\u5f15\u7528\u56fe\u7247","text":"<p>\u5728 Markdown \u6587\u4ef6\u4e2d\u4f7f\u7528\u4ee5\u4e0b\u8bed\u6cd5\u5f15\u7528\u56fe\u7247\uff1a</p> <pre><code>![\u56fe\u7247\u63cf\u8ff0](images/example.png)\n</code></pre>"},{"location":"config/#_12","title":"\u8def\u5f84\u5f15\u7528\u65b9\u5f0f","text":"<ul> <li> <p>\u76f8\u5bf9\u8def\u5f84\uff1a\u4ece\u5f53\u524d Markdown \u6587\u4ef6\u6240\u5728\u76ee\u5f55\u5f00\u59cb\u7684\u8def\u5f84   <code>markdown   ![\u56fe\u7247\u63cf\u8ff0](../images/example.png)  # \u4e0a\u7ea7\u76ee\u5f55\u7684 images \u6587\u4ef6\u5939</code></p> </li> <li> <p>\u7edd\u5bf9\u8def\u5f84\uff1a\u4ece <code>docs</code> \u76ee\u5f55\u5f00\u59cb\u7684\u8def\u5f84\uff08\u63a8\u8350\uff09   <code>markdown   ![\u56fe\u7247\u63cf\u8ff0](/images/example.png)  # \u4ece\u6839\u76ee\u5f55\u5f00\u59cb\u7684\u8def\u5f84</code></p> </li> </ul>"},{"location":"config/#_13","title":"\u56fe\u7247\u4f18\u5316","text":"<ul> <li>\u538b\u7f29\u56fe\u7247\uff1a\u4f7f\u7528\u56fe\u7247\u538b\u7f29\u5de5\u5177\uff08\u5982 TinyPNG\u3001Squoosh \u7b49\uff09\u51cf\u5c0f\u56fe\u7247\u6587\u4ef6\u5927\u5c0f</li> <li>\u9009\u62e9\u5408\u9002\u7684\u683c\u5f0f\uff1a\u6839\u636e\u56fe\u7247\u7c7b\u578b\u9009\u62e9\u5408\u9002\u7684\u683c\u5f0f\uff08\u5982 JPG \u7528\u4e8e\u7167\u7247\uff0cPNG \u7528\u4e8e\u900f\u660e\u80cc\u666f\u56fe\u7247\uff09</li> <li>\u63a7\u5236\u56fe\u7247\u5c3a\u5bf8\uff1a\u6839\u636e\u9875\u9762\u5e03\u5c40\u9700\u8981\u8c03\u6574\u56fe\u7247\u5c3a\u5bf8</li> </ul>"},{"location":"config/#5","title":"5. \u4fee\u6539\u5404\u79cd\u7684\u663e\u793a\u540d\u5b57","text":""},{"location":"config/#_14","title":"\u4fee\u6539\u7ad9\u70b9\u540d\u79f0","text":"<p>\u5728 <code>mkdocs.yml</code> \u6587\u4ef6\u4e2d\u4fee\u6539 <code>site_name</code> \u5b57\u6bb5\uff1a</p> <pre><code>site_name: IE Arch Handbook  # \u4fee\u6539\u4e3a\u4f60\u7684\u7ad9\u70b9\u540d\u79f0\n</code></pre>"},{"location":"config/#url","title":"\u4fee\u6539\u7ad9\u70b9 URL","text":"<p>\u5728 <code>mkdocs.yml</code> \u6587\u4ef6\u4e2d\u4fee\u6539 <code>site_url</code> \u5b57\u6bb5\uff1a</p> <pre><code>site_url: https://h4nkx.github.io/  # \u4fee\u6539\u4e3a\u4f60\u7684\u7ad9\u70b9 URL\n</code></pre>"},{"location":"config/#_15","title":"\u4fee\u6539\u680f\u76ee\u540d\u79f0","text":"<p>\u76f4\u63a5\u4fee\u6539 <code>mkdocs.yml</code> \u6587\u4ef6\u4e2d <code>nav</code> \u90e8\u5206\u7684\u680f\u76ee\u540d\u79f0\uff1a</p> <pre><code>nav:\n  - \u9996\u9875: index.md\n  - \u539f\u680f\u76ee\u540d: section/  # \u4fee\u6539\u4e3a\u65b0\u7684\u680f\u76ee\u540d\n</code></pre>"},{"location":"config/#_16","title":"\u4fee\u6539\u6587\u7ae0\u6807\u9898","text":"<p>\u76f4\u63a5\u4fee\u6539 Markdown \u6587\u4ef6\u4e2d\u7684\u6807\u9898\uff1a</p> <pre><code># \u539f\u6807\u9898  # \u4fee\u6539\u4e3a\u65b0\u7684\u6807\u9898\n</code></pre>"},{"location":"config/#6-github","title":"6. \u5982\u4f55\u90e8\u7f72 GitHub","text":""},{"location":"config/#_17","title":"\u81ea\u52a8\u90e8\u7f72","text":"<ol> <li>\u786e\u4fdd <code>.github/workflows/deploy.yml</code> \u6587\u4ef6\u5df2\u914d\u7f6e\u6b63\u786e</li> <li>\u5c06\u4fee\u6539\u63a8\u9001\u5230 <code>main</code> \u5206\u652f</li> <li>GitHub Actions \u4f1a\u81ea\u52a8\u6267\u884c\u6784\u5efa\u548c\u90e8\u7f72</li> </ol>"},{"location":"config/#_18","title":"\u624b\u52a8\u90e8\u7f72","text":"<p>\u8fd0\u884c\u4ee5\u4e0b\u547d\u4ee4\u624b\u52a8\u6784\u5efa\u5e76\u63a8\u9001\u66f4\u65b0\uff1a</p> <pre><code>mkdocs gh-deploy\n</code></pre>"},{"location":"config/#_19","title":"\u90e8\u7f72\u9a8c\u8bc1","text":"<p>\u90e8\u7f72\u5b8c\u6210\u540e\uff0c\u53ef\u4ee5\u901a\u8fc7\u4ee5\u4e0b URL \u8bbf\u95ee\u7ad9\u70b9\uff1a</p> <pre><code>https://H4nkX.github.io/H4nkX.github.io/\n</code></pre>"},{"location":"config/#_20","title":"\u90e8\u7f72\u95ee\u9898\u6392\u67e5","text":"<ul> <li>\u68c0\u67e5 GitHub Actions \u5de5\u4f5c\u6d41\u662f\u5426\u6210\u529f\u6267\u884c</li> <li>\u68c0\u67e5 <code>gh-pages</code> \u5206\u652f\u662f\u5426\u5b58\u5728\u4e14\u5305\u542b\u7ad9\u70b9\u6587\u4ef6</li> <li>\u68c0\u67e5 GitHub Pages \u8bbe\u7f6e\u662f\u5426\u6b63\u786e\uff08\u4f7f\u7528 <code>gh-pages</code> \u5206\u652f\uff09</li> </ul>"},{"location":"story/","title":"\u5b9e\u6218\u8bb0\u5f55","text":"<p>\u6b22\u8fce\u6765\u5230\u5b9e\u6218\u8bb0\u5f55\u677f\u5757\uff01\u8fd9\u91cc\u8bb0\u5f55\u4e86\u6211\u5728\u5de5\u4e1a\u5de5\u7a0b\u9886\u57df\u7684\u5b9e\u8df5\u7ecf\u9a8c\u548c\u6848\u4f8b\u5206\u4eab\u3002</p>"},{"location":"story/#_2","title":"\u6700\u65b0\u6545\u4e8b","text":"<ul> <li>\u6545\u4e8b1 - \u7b2c\u4e00\u4e2a\u5b9e\u6218\u6848\u4f8b</li> <li>\u6545\u4e8b2 - \u7b2c\u4e8c\u4e2a\u5b9e\u6218\u6848\u4f8b</li> <li>\u6545\u4e8b3 - \u7b2c\u4e09\u4e2a\u5b9e\u6218\u6848\u4f8b</li> </ul>"},{"location":"story/#_3","title":"\u5173\u4e8e\u5b9e\u6218\u8bb0\u5f55","text":"<p>\u5b9e\u6218\u8bb0\u5f55\u662f\u6211\u5728\u5b9e\u9645\u5de5\u4f5c\u4e2d\u9047\u5230\u7684\u95ee\u9898\u3001\u89e3\u51b3\u65b9\u6848\u548c\u7ecf\u9a8c\u603b\u7ed3\u3002\u5e0c\u671b\u80fd\u5bf9\u4f60\u6709\u6240\u5e2e\u52a9\uff01</p>"},{"location":"story/story1/","title":"\u6545\u4e8b1","text":"<p>\u6545\u4e8b1\u5185\u5bb9 - \u5f85\u66f4\u65b0</p>"},{"location":"story/story2/","title":"\u6545\u4e8b2","text":"<p>\u6545\u4e8b2\u5185\u5bb9 - \u5f85\u66f4\u65b0</p>"},{"location":"story/story3/","title":"\u6545\u4e8b3","text":"<p>\u6545\u4e8b3\u5185\u5bb9 - \u5f85\u66f4\u65b0</p>"},{"location":"yunchou/","title":"\u8fd0\u7b79\u5b66","text":"<p>\u6b22\u8fce\u6765\u5230\u8fd0\u7b79\u5b66\u677f\u5757\uff01\u8fd9\u91cc\u6574\u7406\u4e86\u8fd0\u7b79\u5b66\u76f8\u5173\u7684\u7406\u8bba\u77e5\u8bc6\u548c\u5b9e\u7528\u516c\u5f0f\u3002</p>"},{"location":"yunchou/#_2","title":"\u5185\u5bb9\u76ee\u5f55","text":"<ul> <li>\u8bb2\u89e31 - \u8fd0\u7b79\u5b66\u57fa\u7840\u8bb2\u89e3</li> </ul>"},{"location":"yunchou/#_3","title":"\u5173\u4e8e\u8fd0\u7b79\u5b66","text":"<p>\u8fd0\u7b79\u5b66\u662f\u4e00\u95e8\u5e94\u7528\u6570\u5b66\u5b66\u79d1\uff0c\u7528\u4e8e\u89e3\u51b3\u590d\u6742\u7cfb\u7edf\u4e2d\u7684\u4f18\u5316\u95ee\u9898\u3002\u5728\u5de5\u4e1a\u5de5\u7a0b\u4e2d\u6709\u7740\u5e7f\u6cdb\u7684\u5e94\u7528\u3002</p>"},{"location":"yunchou/teach/","title":"\u8bb2\u89e31","text":""},{"location":"yunchou/teach/#_1","title":"\u7ebf\u6027\u89c4\u5212\u95ee\u9898","text":"<p>\u7ebf\u6027\u89c4\u5212\u7684\u6807\u51c6\u5f62\u5f0f\uff1a</p> <p>$$ \\begin{aligned} \\text{\u6700\u5927\u5316} \\quad &amp; c^T x \\ \\text{ subject to} \\quad &amp; Ax \\leq b \\ &amp; x \\geq 0 \\end{aligned} $$</p>"},{"location":"yunchou/teach/#_2","title":"\u5fae\u79ef\u5206\u516c\u5f0f","text":"<p>\u5b9a\u79ef\u5206\uff1a</p> <p>$$ \\int_{a}^{b} f(x) dx = F(b) - F(a) $$</p> <p>\u4e8c\u91cd\u79ef\u5206\uff1a</p> <p>$$ \\iint_{D} f(x, y) dA = \\int_{a}^{b} \\int_{g_1(x)}^{g_2(x)} f(x, y) dy dx $$</p>"},{"location":"yunchou/teach/#_3","title":"\u6982\u7387\u8bba\u516c\u5f0f","text":"<p>\u6b63\u6001\u5206\u5e03\u6982\u7387\u5bc6\u5ea6\u51fd\u6570\uff1a</p> <p>$$  f(x) = \\frac{1}{\\sigma \\sqrt{2\\pi}} e^{-\\frac{(x - \\mu)^2}{2\\sigma^2}} $$</p>"},{"location":"yunchou/teach/#_4","title":"\u77e9\u9635\u8fd0\u7b97","text":"<p>\u77e9\u9635\u4e58\u6cd5\uff1a</p> <p>$$  C = A \\times B \\quad \\text{\u5176\u4e2d} \\quad C_{ij} = \\sum_{k=1}^{n} A_{ik} B_{kj} $$</p> <p>\u7279\u5f81\u503c\u95ee\u9898\uff1a</p> <p>$$  A v = \\lambda v $$</p>"},{"location":"blog/archive/2024/","title":"2024","text":""},{"location":"blog/category/%E9%9A%8F%E7%AC%94/","title":"\u968f\u7b14","text":""}]}